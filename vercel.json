{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/cron/ingest/api",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ingest/scrapers-venue",
      "schedule": "15 2 * * *"
    },
    {
      "path": "/api/cron/ingest/humanitix",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/ingest/oztix",
      "schedule": "45 2 * * *"
    },
    {
      "path": "/api/cron/ingest/scrapers-platform-small",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ingest/ticketmaster",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/ingest/moshtix",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/backfill-descriptions",
      "schedule": "0 4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
