# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/eventure?schema=public"

# ── Site URL ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://eventure.com.au"

# ── Ingestion: API Keys ──────────────────────────────
EVENTBRITE_API_KEY=""
TICKETMASTER_API_KEY=""
EVENTFINDA_USERNAME=""
EVENTFINDA_PASSWORD=""
STICKY_TICKETS_TOKEN=""

# ── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ── Ingestion: Cron Auth ─────────────────────────────
CRON_SECRET=""

# ── Google Maps ──────────────────────────────────────
# Maps Embed API key — used for venue maps on event detail pages.
# Create at https://console.cloud.google.com/apis/credentials
# Enable "Maps Embed API" and restrict to HTTP referrers.
# Falls back to OpenStreetMap when not set.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
