generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  url         String?  // Original event URL

  // Location
  venueName   String?
  venueAddress String?
  city        String   @default("Gold Coast")
  state       String   @default("QLD")
  country     String   @default("AU")
  latitude    Float?
  longitude   Float?

  // Categorisation
  category    EventCategory @default(OTHER)
  tags        String[]      @default([])

  // Pricing
  isFree      Boolean  @default(false)
  priceMin    Float?
  priceMax    Float?
  currency    String   @default("AUD")
  ticketUrl   String?

  // Ticketing & monetisation (Stage 2 — captured from day one)
  ticketProvider     String?              // e.g. "eventbrite", "ticketmaster"
  ticketAvailability TicketAvailability?
  priceTiers         Json?                // Array of { name, price, currency }
  affiliateEligible  Boolean  @default(false)
  affiliateUrl       String?              // Affiliate-tagged URL (populated later)

  // Ingestion metadata
  source      String   // e.g. "eventbrite", "destinationgc", "hota"
  sourceId    String   // ID from the source system
  sourceUrl   String?  // URL on the source site
  lastScrapedAt DateTime @default(now())
  rawData     Json?    // Original data from source for debugging

  // Publishing
  status      EventStatus @default(draft)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Discussions (v1: optional event-attached threads)
  discussionThreads Thread[] @relation("EventThreads")

  @@unique([source, sourceId]) // Prevent duplicate imports from same source
  @@index([startDate, status])
  @@index([city, startDate])
  @@index([category, startDate])
  @@index([slug])
}

enum EventCategory {
  MUSIC
  FESTIVAL
  MARKETS
  SPORTS
  FAMILY
  NIGHTLIFE
  FOOD_DRINK
  ARTS
  COMMUNITY
  COMEDY
  THEATRE
  OUTDOOR
  OTHER
}

enum EventStatus {
  draft
  published
  cancelled
  past
}

enum TicketAvailability {
  available
  limited
  sold_out
}

// ── Auth ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // Discussions
  threads        Thread[]
  replies        Reply[]
  threadUpvotes  ThreadUpvote[]
  replyUpvotes   ReplyUpvote[]
  threadReports  ThreadReport[]
  replyReports   ReplyReport[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Discussions ──────────────────────────────────────

model Thread {
  id            String             @id @default(cuid())
  slug          String             @unique
  title         String             @db.VarChar(120)
  body          String             @db.Text
  category      DiscussionCategory
  cityId        String             @default("gold-coast")
  authorId      String
  author        User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  linkedEventId String?
  linkedEvent   Event?             @relation("EventThreads", fields: [linkedEventId], references: [id], onDelete: SetNull)
  upvoteCount   Int                @default(0)
  replyCount    Int                @default(0)
  hotScore      Float              @default(0)
  editedAt      DateTime?
  deletedAt     DateTime?
  hiddenAt      DateTime?
  hiddenById    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  replies       Reply[]
  upvotes       ThreadUpvote[]
  reports       ThreadReport[]

  @@index([cityId, hotScore(sort: Desc), createdAt(sort: Desc)])
  @@index([cityId, category, createdAt(sort: Desc)])
  @@index([linkedEventId])
  @@index([authorId])
}

model Reply {
  id          String        @id @default(cuid())
  threadId    String
  thread      Thread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body        String        @db.Text
  upvoteCount Int           @default(0)
  editedAt    DateTime?
  deletedAt   DateTime?
  hiddenAt    DateTime?
  hiddenById  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  upvotes     ReplyUpvote[]
  reports     ReplyReport[]

  @@index([threadId, createdAt])
  @@index([threadId, upvoteCount(sort: Desc)])
}

model ThreadUpvote {
  threadId  String
  userId    String
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
}

model ReplyUpvote {
  replyId   String
  userId    String
  createdAt DateTime @default(now())
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([replyId, userId])
  @@index([userId])
}

model ThreadReport {
  id         String       @id @default(cuid())
  threadId   String
  reporterId String
  reason     ReportReason
  detail     String?      @db.Text
  status     ReportStatus @default(open)
  createdAt  DateTime     @default(now())
  thread     Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([threadId, reporterId])
  @@index([status, createdAt])
}

model ReplyReport {
  id         String       @id @default(cuid())
  replyId    String
  reporterId String
  reason     ReportReason
  detail     String?      @db.Text
  status     ReportStatus @default(open)
  createdAt  DateTime     @default(now())
  reply      Reply        @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([replyId, reporterId])
  @@index([status, createdAt])
}

enum DiscussionCategory {
  general
  music
  festivals
  nightlife
  markets
  family
  food_drink
  arts
  comedy
  theatre
  outdoor
  community
}

enum ReportReason {
  spam
  harassment
  off_topic
  other
}

enum ReportStatus {
  open
  reviewed
  actioned
  dismissed
}
